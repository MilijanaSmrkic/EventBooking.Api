{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EventBookingDb;Trusted_Connection=True;"
  },
  "JwtSettings": {
    "SecretKey": "EventBooking-SuperSecret-Key-2024-MinLength32Chars!",
    "Issuer": "EventBooking.Api",
    "Audience": "EventBooking.Client",
    "ExpiryMinutes": 60
  },
  "EmailTemplates": {
    "ReservationApproved": {
      "Subject": "Reservation Approved – {EventTitle}",
      "Body": "Your reservation has been approved.\n\nReservation details:\n- Event: {EventTitle}\n- Date: {ReservationDate}\n- Seats: {SeatNumbers}\n- Reservation ID: {ReservationId}"
    }
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "From": "noreply@eventbooking.com"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/eventbooking-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
